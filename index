<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>VAST Form Part 4 Practice Checklist</title>
  <style>
    :root {
      --bg: #eef6fb;
      --panel: rgba(255,255,255,0.82);
      --panel-strong: #ffffff;
      --ink: #17324d;
      --muted: #5b7086;
      --line: #c5d8e8;
      --blue: #67a8d6;
      --blue-dark: #2b6f9f;
      --blue-soft: #d9ebf8;
      --accent: #1f8ae0;
      --shadow: 0 12px 30px rgba(24, 55, 88, 0.12);
      --radius: 22px;
    }

    * { box-sizing: border-box; }

    body {
      margin: 0;
      font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      color: var(--ink);
      background:
        radial-gradient(circle at top left, rgba(103,168,214,0.22), transparent 32%),
        radial-gradient(circle at bottom right, rgba(31,138,224,0.14), transparent 28%),
        linear-gradient(180deg, #f4faff 0%, #e9f3fb 100%);
      min-height: 100vh;
    }

    .wrap {
      width: min(1180px, calc(100% - 28px));
      margin: 24px auto 40px;
    }

    .hero {
      background: linear-gradient(135deg, rgba(255,255,255,0.92), rgba(230,242,252,0.88));
      border: 1px solid rgba(197,216,232,0.9);
      border-radius: 28px;
      padding: 28px;
      box-shadow: var(--shadow);
      backdrop-filter: blur(10px);
    }

    .eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: var(--blue-soft);
      color: var(--blue-dark);
      border: 1px solid #bcd8eb;
      border-radius: 999px;
      padding: 6px 12px;
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }

    h1 {
      margin: 14px 0 8px;
      font-size: clamp(2rem, 4vw, 3.2rem);
      line-height: 1.02;
    }

    .hero p {
      margin: 0;
      max-width: 820px;
      color: var(--muted);
      font-size: 1rem;
      line-height: 1.6;
    }

    .top-grid {
      display: grid;
      grid-template-columns: 1.3fr 0.9fr;
      gap: 20px;
      margin-top: 20px;
    }

    .card {
      background: var(--panel);
      border: 1px solid rgba(197,216,232,0.9);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      backdrop-filter: blur(10px);
    }

    .meta {
      padding: 20px;
    }

    .meta-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 14px;
    }

    .field label {
      display: block;
      font-size: 0.82rem;
      font-weight: 700;
      color: var(--blue-dark);
      margin-bottom: 8px;
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }

    .field input, .field textarea, .field select {
      width: 100%;
      border: 1px solid var(--line);
      border-radius: 14px;
      background: rgba(255,255,255,0.92);
      padding: 12px 14px;
      font: inherit;
      color: var(--ink);
      outline: none;
      transition: 0.2s ease;
    }

    .field textarea {
      resize: vertical;
      min-height: 110px;
    }

    .field input:focus, .field textarea:focus, .field select:focus {
      border-color: var(--accent);
      box-shadow: 0 0 0 4px rgba(31,138,224,0.12);
    }

    .stack { display: grid; gap: 14px; }

    .guide {
      padding: 20px;
    }

    .guide h2, .section h2 {
      margin: 0 0 12px;
      font-size: 1.05rem;
    }

    .guide p, .guide li {
      color: var(--muted);
      line-height: 1.55;
      font-size: 0.95rem;
    }

    .guide ul {
      margin: 0;
      padding-left: 18px;
    }

    .rating-bar {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 10px;
      margin-top: 16px;
    }

    .rating-pill {
      border-radius: 16px;
      padding: 14px;
      text-align: center;
      border: 1px solid #c3d8ea;
      background: linear-gradient(180deg, #ffffff, #edf6fd);
    }

    .rating-pill strong {
      display: block;
      font-size: 1.3rem;
      color: var(--blue-dark);
    }

    .sections {
      display: grid;
      gap: 20px;
      margin-top: 22px;
    }

    .section {
      overflow: hidden;
    }

    .section-header {
      padding: 18px 22px;
      background: linear-gradient(180deg, #81b8df, #69a9d6);
      color: white;
      display: flex;
      justify-content: space-between;
      align-items: end;
      gap: 18px;
    }

    .section-header h2 {
      margin: 0;
      font-size: 1.2rem;
    }

    .section-header p {
      margin: 4px 0 0;
      opacity: 0.95;
      max-width: 780px;
      line-height: 1.45;
      font-size: 0.95rem;
    }

    .section-body {
      padding: 20px;
      background: rgba(255,255,255,0.82);
    }

    .item-list {
      display: grid;
      gap: 12px;
    }

    .item {
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 14px;
      align-items: start;
      padding: 14px 16px;
      border: 1px solid #d8e7f3;
      border-radius: 18px;
      background: linear-gradient(180deg, rgba(255,255,255,0.95), rgba(240,247,253,0.92));
      transition: 0.2s ease;
    }

    .item:hover {
      transform: translateY(-1px);
      box-shadow: 0 8px 20px rgba(30, 73, 111, 0.08);
    }

    .item input[type="checkbox"] {
      appearance: none;
      width: 24px;
      height: 24px;
      border-radius: 8px;
      border: 2px solid #8bb8da;
      margin-top: 2px;
      background: white;
      cursor: pointer;
      position: relative;
      transition: 0.2s ease;
    }

    .item input[type="checkbox"]:checked {
      background: var(--accent);
      border-color: var(--accent);
    }

    .item input[type="checkbox"]:checked::after {
      content: "✓";
      position: absolute;
      inset: 0;
      display: grid;
      place-items: center;
      color: white;
      font-size: 16px;
      font-weight: 900;
    }

    .item label {
      cursor: pointer;
      line-height: 1.5;
    }

    .item.done {
      opacity: 0.68;
    }

    .item.done label {
      text-decoration: line-through;
    }

    .notes-grid {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 16px;
      align-items: start;
      margin-top: 18px;
    }

    .score-box {
      width: 170px;
      background: linear-gradient(180deg, #fff, #f1f8fe);
      border: 1px solid var(--line);
      border-radius: 18px;
      padding: 16px;
    }

    .score-box label {
      display: block;
      margin-bottom: 10px;
      font-size: 0.82rem;
      font-weight: 700;
      color: var(--blue-dark);
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }

    .score-box .score-options {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 8px;
    }

    .score-box button {
      border: 1px solid var(--line);
      background: white;
      border-radius: 12px;
      padding: 10px 0;
      font: inherit;
      font-weight: 800;
      cursor: pointer;
      color: var(--ink);
    }

    .score-box button.active {
      background: var(--accent);
      color: white;
      border-color: var(--accent);
    }

    .toolbar {
      position: sticky;
      bottom: 14px;
      z-index: 10;
      display: flex;
      gap: 10px;
      justify-content: center;
      flex-wrap: wrap;
      margin-top: 24px;
    }

    .toolbar button {
      border: none;
      border-radius: 999px;
      padding: 12px 18px;
      font: inherit;
      font-weight: 700;
      cursor: pointer;
      box-shadow: var(--shadow);
    }

    .primary { background: var(--accent); color: white; }
    .secondary { background: white; color: var(--ink); border: 1px solid var(--line); }

    .progress {
      margin-top: 16px;
      display: flex;
      align-items: center;
      gap: 12px;
      flex-wrap: wrap;
    }

    .bar {
      flex: 1;
      min-width: 220px;
      height: 14px;
      background: #d9ebf8;
      border-radius: 999px;
      overflow: hidden;
    }

    .bar > span {
      display: block;
      height: 100%;
      width: 0;
      background: linear-gradient(90deg, #62a9d8, #1f8ae0);
      transition: width 0.25s ease;
    }

    .progress small {
      color: var(--muted);
      font-size: 0.9rem;
    }

    .footer-note {
      margin-top: 18px;
      color: var(--muted);
      font-size: 0.9rem;
      line-height: 1.5;
    }

    @media (max-width: 920px) {
      .top-grid { grid-template-columns: 1fr; }
      .notes-grid { grid-template-columns: 1fr; }
      .score-box { width: 100%; }
    }

    @media (max-width: 640px) {
      .wrap { width: min(100% - 16px, 1000px); }
      .hero, .meta, .guide, .section-body { padding: 16px; }
      .section-header { padding: 16px; }
      .meta-grid { grid-template-columns: 1fr; }
      .item { padding: 12px 14px; }
    }
  </style>
</head>
<body>
  <div class="wrap">
    <section class="hero card">
      <div class="eyebrow">VAST Form · Part 4 · Behaviour Practice</div>
      <h1>Facilitation observation checklist</h1>
      <p>Digital practice version for observing and reflecting on facilitation behaviours across Techniques, Artistry, and Values. Designed for on-screen use during practice sessions without needing to print.</p>
      <div class="progress">
        <div class="bar"><span id="progressFill"></span></div>
        <small id="progressText">0 of 33 items completed</small>
      </div>
    </section>

    <div class="top-grid">
      <section class="meta card">
        <div class="meta-grid">
          <div class="field"><label for="date">Date</label><input id="date" type="date" /></div>
          <div class="field"><label for="session">Session</label><input id="session" type="text" placeholder="e.g. Airway simulation" /></div>
          <div class="field"><label for="facilitator">Facilitator</label><input id="facilitator" type="text" placeholder="Name" /></div>
          <div class="field"><label for="observer">Observer</label><input id="observer" type="text" placeholder="Name" /></div>
        </div>
      </section>

      <aside class="guide card">
        <h2>Guidance</h2>
        <ul>
          <li>The competencies listed should trigger observations on performance.</li>
          <li>Observations of behaviour need not relate to all competencies.</li>
          <li>If scoring, rate the overall influence facilitation had on learning and on the simulation environment for each category.</li>
        </ul>
        <div class="rating-bar">
          <div class="rating-pill"><strong>1</strong>Harmful influence</div>
          <div class="rating-pill"><strong>2</strong>Neutral influence</div>
          <div class="rating-pill"><strong>3</strong>Valuable influence</div>
        </div>
      </aside>
    </div>

    <main class="sections" id="sections"></main>

    <div class="toolbar">
      <button class="primary" id="saveBtn">Save in browser</button>
      <button class="secondary" id="exportBtn">Export summary</button>
      <button class="secondary" id="resetBtn">Reset checklist</button>
    </div>

    <p class="footer-note">This digital checklist is based on the uploaded VAST Form Part 4 Behaviour checklist content, including the three categories and rating guidance.</p>
  </div>

  <script>
    const data = [
      {
        key: 'techniques',
        title: 'TECHNIQUES',
        subtitle: 'The practical approaches and micro-skills of facilitation',
        items: [
          'Organises the learning environment pre-session',
          'Confirms equipment setup and function pre-scenario',
          'Sets clear expectations',
          'Demonstrates familiarity with session objectives and scenario content',
          'Provides clear orientations and briefings',
          'Facilitates the scenario discreetly',
          'Promotes scenario realism',
          'Uses a structured approach to debriefing',
          'Effectively uses verbal and non-verbal communication',
          'Focuses on learning objectives, core concepts, and non-technical skills',
          'Generates questions that explore thought processes, behaviours, and decision making',
          'Listens with attention, confirming the speaker’s message, and asking follow-up questions',
          'Identifies important performance actions and omissions respectfully',
          'Distils the debriefing discussion into specific learning that can be applied clinically'
        ]
      },
      {
        key: 'artistry',
        title: 'ARTISTRY',
        subtitle: 'The dynamic, creative, and individualised nature of facilitation',
        items: [
          'Makes minor adjustments to learning resources in response to the learners and context',
          'Maintains awareness of logistics, time management, and course flow',
          'Collaborates within the facilitation team',
          'Maintains task focus and presence when faced with increasing cognitive load',
          'Anticipates potential obstacles and makes contingency plans',
          'Adapts facilitation to suit learners’ background, knowledge, and performance',
          'Recognises potential language barriers, modifies approach, and checks for understanding',
          'Encourages active participation and contribution from all participants',
          'Responds to challenging debriefing situations'
        ]
      },
      {
        key: 'values',
        title: 'VALUES',
        subtitle: 'The fundamental principles forming the foundation of facilitation practice',
        items: [
          'Establishes and maintains a safe learning environment',
          'Builds rapport with learners and validates their contributions',
          'Supports learner-centred debriefing conversations',
          'Recognises and responds to participant distress',
          'Facilitates with passion and enthusiasm',
          'Demonstrates curiosity regarding the influence of cultural and contextual factors',
          'Appears open to different perspectives and learning from others',
          'Engages sensitively and with respect for cultural norms',
          'Demonstrates humility'
        ]
      }
    ];

    const storageKey = 'vast-form-part4-practice';
    const sectionsEl = document.getElementById('sections');
    const progressFill = document.getElementById('progressFill');
    const progressText = document.getElementById('progressText');

    function createSection(section) {
      const article = document.createElement('section');
      article.className = 'section card';

      const itemsHtml = section.items.map((text, index) => {
        const id = `${section.key}-${index}`;
        return `
          <div class="item" data-item>
            <input type="checkbox" id="${id}" data-key="${id}" />
            <label for="${id}">${text}</label>
          </div>
        `;
      }).join('');

      article.innerHTML = `
        <div class="section-header">
          <div>
            <h2>${section.title}</h2>
            <p>${section.subtitle}</p>
          </div>
        </div>
        <div class="section-body">
          <div class="item-list">${itemsHtml}</div>
          <div class="notes-grid">
            <div class="field">
              <label for="${section.key}-notes">Other / Notes</label>
              <textarea id="${section.key}-notes" data-notes="${section.key}" placeholder="Add observations, examples, or coaching points..."></textarea>
            </div>
            <div class="score-box">
              <label>Score</label>
              <div class="score-options">
                <button type="button" data-score-group="${section.key}" data-score="1">1</button>
                <button type="button" data-score-group="${section.key}" data-score="2">2</button>
                <button type="button" data-score-group="${section.key}" data-score="3">3</button>
              </div>
            </div>
          </div>
        </div>
      `;

      sectionsEl.appendChild(article);
    }

    data.forEach(createSection);

    function getState() {
      const state = {
        meta: {
          date: document.getElementById('date').value,
          session: document.getElementById('session').value,
          facilitator: document.getElementById('facilitator').value,
          observer: document.getElementById('observer').value
        },
        checks: {},
        notes: {},
        scores: {}
      };

      document.querySelectorAll('input[type="checkbox"][data-key]').forEach(cb => {
        state.checks[cb.dataset.key] = cb.checked;
      });

      document.querySelectorAll('textarea[data-notes]').forEach(area => {
        state.notes[area.dataset.notes] = area.value;
      });

      document.querySelectorAll('[data-score-group]').forEach(btn => {
        if (btn.classList.contains('active')) {
          state.scores[btn.dataset.scoreGroup] = btn.dataset.score;
        }
      });

      return state;
    }

    function applyState(state) {
      if (!state) return;

      document.getElementById('date').value = state.meta?.date || '';
      document.getElementById('session').value = state.meta?.session || '';
      document.getElementById('facilitator').value = state.meta?.facilitator || '';
      document.getElementById('observer').value = state.meta?.observer || '';

      document.querySelectorAll('input[type="checkbox"][data-key]').forEach(cb => {
        cb.checked = Boolean(state.checks?.[cb.dataset.key]);
        cb.closest('[data-item]').classList.toggle('done', cb.checked);
      });

      document.querySelectorAll('textarea[data-notes]').forEach(area => {
        area.value = state.notes?.[area.dataset.notes] || '';
      });

      document.querySelectorAll('[data-score-group]').forEach(btn => {
        const active = state.scores?.[btn.dataset.scoreGroup] === btn.dataset.score;
        btn.classList.toggle('active', active);
      });

      updateProgress();
    }

    function saveState() {
      localStorage.setItem(storageKey, JSON.stringify(getState()));
    }

    function updateProgress() {
      const checks = [...document.querySelectorAll('input[type="checkbox"][data-key]')];
      const done = checks.filter(cb => cb.checked).length;
      const total = checks.length;
      const pct = total ? (done / total) * 100 : 0;
      progressFill.style.width = `${pct}%`;
      progressText.textContent = `${done} of ${total} items completed`;
    }

    document.querySelectorAll('input[type="checkbox"][data-key]').forEach(cb => {
      cb.addEventListener('change', () => {
        cb.closest('[data-item]').classList.toggle('done', cb.checked);
        updateProgress();
        saveState();
      });
    });

    document.querySelectorAll('textarea, input[type="text"], input[type="date"]').forEach(el => {
      el.addEventListener('input', saveState);
    });

    document.querySelectorAll('[data-score-group]').forEach(btn => {
      btn.addEventListener('click', () => {
        const group = btn.dataset.scoreGroup;
        document.querySelectorAll(`[data-score-group="${group}"]`).forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        saveState();
      });
    });

    document.getElementById('saveBtn').addEventListener('click', () => {
      saveState();
      alert('Saved in this browser.');
    });

    document.getElementById('resetBtn').addEventListener('click', () => {
      if (!confirm('Reset all checks, notes, and scores?')) return;
      localStorage.removeItem(storageKey);
      applyState({ meta: {}, checks: {}, notes: {}, scores: {} });
    });

    document.getElementById('exportBtn').addEventListener('click', () => {
      const state = getState();
      const lines = [];
      lines.push('VAST Form Part 4 Practice Summary');
      lines.push('');
      lines.push(`Date: ${state.meta.date || ''}`);
      lines.push(`Session: ${state.meta.session || ''}`);
      lines.push(`Facilitator: ${state.meta.facilitator || ''}`);
      lines.push(`Observer: ${state.meta.observer || ''}`);
      lines.push('');

      data.forEach(section => {
        lines.push(`${section.title} (${state.scores[section.key] || 'No score'})`);
        section.items.forEach((item, index) => {
          const key = `${section.key}-${index}`;
          const mark = state.checks[key] ? '[x]' : '[ ]';
          lines.push(`${mark} ${item}`);
        });
        lines.push(`Notes: ${state.notes[section.key] || ''}`);
        lines.push('');
      });

      const blob = new Blob([lines.join('\n')], { type: 'text/plain;charset=utf-8' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = 'vast-form-part4-summary.txt';
      a.click();
      URL.revokeObjectURL(url);
    });

    const saved = localStorage.getItem(storageKey);
    applyState(saved ? JSON.parse(saved) : { meta: {}, checks: {}, notes: {}, scores: {} });
  </script>
</body>
</html>
